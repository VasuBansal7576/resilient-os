HYDRADB_API_KEY=
HYDRADB_TENANT_ID=resilient-os
HYDRADB_SUB_TENANT_ID=resilient-os

# Real LLM providers. Groq is primary; NVIDIA is fallback.
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile
GROQ_PLANNER_MODEL=llama-3.3-70b-versatile
NVIDIA_API_KEY=
NVIDIA_MODEL=openai/meta/llama-3.3-70b-instruct
NVIDIA_PLANNER_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Planner: auto uses Groq/NVIDIA when configured; scripted builds a deterministic real-tool plan.
AGENT_MODE=auto

# Real notification channel. Configure at least one.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

SCRAPEGRAPH_HEADLESS=true
SCRAPEGRAPH_VERBOSE=false

# Local persistence for resilience caches.
RESILIENT_OS_LOCAL_GRAPH=.resilient_os/local_graph.jsonl
RESILIENT_OS_TOOL_CACHE=.resilient_os/tool_cache.jsonl
